{
  "manifest_version": 3,
  "name": "Yuumi",
  "version": "1.3",
  "description": "Chevauchant son Grimoire, Yuumi bondit sur Airtable pour y greffer des boutons magiques et des portails vers d'autres dimensions.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://hooks.airtable.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://airtable.com/*"],
      "js": [
        "config.js",
        "menu.js",
        "form.js",
        "tables.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}