{
  "manifest_version": 3,

  "name": "Yuumi, compagnon Airtable",
  "short_name": "Yuumi",

  "version": "2.0.0",
  "version_name": "2.0 - Refonte UI/UX",

  "description": "Chevauchant son Grimoire, Yuumi bondit sur Airtable pour y greffer des boutons magiques et des portails vers d'autres dimensions.",

  "author": "Nawfel",

  "homepage_url": "https://github.com/Noferu/yuumi-for-airtable",

  "minimum_chrome_version": "114",

  "offline_enabled": true,

  "incognito": "split",

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://airtable.com/*",
    "https://hooks.airtable.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "action": {
    "default_title": "Yuumi",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://airtable.com/*"],
      "js": [
        "content/config.js",
        "content/menu.js",
        "content/form.js",
        "content/tables.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon16.png",
        "assets/icon48.png",
        "assets/icon128.png"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "resources": [
        "popup/*.css",
        "popup/*.js"
      ],
      "matches": ["https://airtable.com/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },

  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}